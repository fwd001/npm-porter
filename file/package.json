{
  "name": "@lhcz/spider-comp",
  "version": "2.5.1",
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/index.js",
  "types": "dist/index.d.ts",
  "unpkg": "dist/index.iife.js",
  "exports": {
    "./dist/style.css": "./dist/style.css",
    "./css": "./dist/style.css",
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "scripts": {
    "docs:dev": "vitepress dev docs --port 8000 --open",
    "docs:build": "vitepress build docs",
    "docs:deploy": "sh scripts/deploy.sh",
    "dev": "vite --mode dev",
    "pub": "sh scripts/publish.sh",
    "push": "sh scripts/push.sh",
    "build": "run-s format clean build:lib",
    "format": "prettier --write src/ packages/",
    "clean": "rimraf ./dist",
    "rm:nm": "find . -type d -name \"node_modules\" -exec rm -rf {} +",
    "build:lib": "run-p type-check build:es ",
    "type-check": "vue-tsc --noEmit",
    "build:es": "vite build",
    "build:browser": "vite -f iife build",
    "preview": "vite preview",
    "upload:dt": "rm -rf ../intelli-case/src/lc-components/spider && mkdir ../intelli-case/src/lc-components/spider && cp -r ./dist/* ../intelli-case/src/lc-components/spider",
    "re:dt": "npm run build && npm run upload:dt",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@lhcz/spider-comp": "2.0.0-beta.3",
    "@tanstack/vue-query": "^5.92.5",
    "@tanstack/vue-query-devtools": "^6.1.3",
    "@tanstack/vue-virtual": "^3.13.16",
    "@vicons/fa": "^0.13.0",
    "@vicons/ionicons5": "^0.13.0",
    "@vuepic/vue-datepicker": "^9.0.3",
    "@vueuse/core": "11.1.0",
    "@vueuse/integrations": "11.1.0",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.7.9",
    "core-js": "^3.39.0",
    "date-fns": "^3.6.0",
    "dayjs": "^1.11.13",
    "lodash-es": "^4.17.22",
    "naive-ui": "^2.40.3",
    "number-precision": "^1.6.0",
    "tinymce": "^5.10.9",
    "vue": "^3.5.13",
    "vue-request": "^2.0.4",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rushstack/eslint-patch": "^1.10.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.17.10",
    "@unocss/preset-rem-to-px": "^0.61.9",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.17.0",
    "eslint-define-config": "^1.24.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-vue": "^9.32.0",
    "less": "^4.2.1",
    "minimist": "^1.2.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "5.6.2",
    "uno-prefix-variant": "^0.0.3",
    "unocss": "^0.61.9",
    "unplugin-vue-components": "^0.27.5",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^3.9.1",
    "vitepress": "^1.5.0",
    "vue-tsc": "^2.1.10"
  },
  "sideEffects": false,
  "description": "Vue3 UI Components Library.",
  "repository": {
    "type": "git",
    "url": "git+http://git.lhcz.local:83/fe/spider-comp.git"
  },
  "keywords": [
    "Vue3",
    "TS",
    "Vite",
    "Less",
    "Components",
    "Tools",
    "Functions"
  ],
  "author": "wendong.fu",
  "license": "MIT",
  "bugs": {
    "url": "http://git.lhcz.local:83/fe/spider-comp.git"
  },
  "homepage": "http://git.lhcz.local:83/fe/spider-comp.git",
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
